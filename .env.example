# Nexus 1.0.0 Automation — environment configuration
# Copy to .env and fill in values before running any scripts.
#
# Run order reference:
#   Stage 1 (before entra/01):  fill ENTRA_* + CONNECTOR_NAME + COPILOT_AGENT_NAME
#   Auto-written by scripts:    ENTRA_CLIENT_ID, ENTRA_CLIENT_SECRET, NEXUS_*_PLUGIN_ID, NEXUS_POLICY_ID, NEXUS_AI_CONNECTOR_ID
#   Infrastructure (when ready): NEXUS_*, CLOUDFS_*, AD_*, PPAC_*

# ── Entra / Azure AD ──────────────────────────────────────────────────────────
ENTRA_TENANT_ID=
ENTRA_APP_NAME=Panzura-Nexus
ENTRA_APP_OBJECT_ID=           # auto-written by entra/01
ENTRA_CLIENT_ID=               # auto-written by entra/01
ENTRA_CLIENT_SECRET=           # auto-written by entra/03

# ── Power Apps / Copilot Studio ───────────────────────────────────────────────
CONNECTOR_NAME=Panzura-Nexus-Connector
COPILOT_AGENT_NAME=Panzura Nexus Assistant
PPAC_ENVIRONMENT_NAME=         # e.g. "Default-<guid>" — set when Power Platform env is ready
PPAC_ENVIRONMENT_URL=          # e.g. https://org12345.crm.dynamics.com

# ── Nexus VM ──────────────────────────────────────────────────────────────────
NEXUS_IP=                      # IP or FQDN of Nexus VM
NEXUS_ADMIN_USER=admin
NEXUS_ADMIN_PASSWORD=
NEXUS_LICENSE_KEY=
NEXUS_SKIP_SSL_VERIFY=false    # set true for self-signed cert in lab
NEXUS_STORAGE_PLUGIN_ID=       # auto-written by nexus/01
NEXUS_AI_PLUGIN_ID=            # auto-written by nexus/02
NEXUS_IAM_PLUGIN_ID=           # auto-written by nexus/03
NEXUS_POLICY_ID=               # auto-written by nexus/05
NEXUS_AI_CONNECTOR_ID=         # auto-written by nexus/06

# ── CloudFS ───────────────────────────────────────────────────────────────────
CLOUDFS_MASTER_NODE=           # FQDN or IP of master node
CLOUDFS_SUBORDINATE_NODES=     # comma-separated FQDNs/IPs of subordinate nodes (if any)
CLOUDFS_ADMIN_USER=admin
CLOUDFS_ADMIN_PASSWORD=
CLOUDFS_SMB_NODE=              # FQDN or IP of SMB-facing node
CLOUDFS_SMB_USER=
CLOUDFS_SMB_PASSWORD=
CLOUDFS_DOMAIN=                # Windows domain for SMB auth, e.g. corp.example.com
CLOUDFS_VERSION=8.7.0

# ── On-premises Active Directory ──────────────────────────────────────────────
AD_HOST=                       # FQDN or IP of domain controller
AD_DOMAIN=                     # e.g. corp.example.com
AD_BIND_USER=                  # service account UPN or sAMAccountName
AD_BIND_PASSWORD=
